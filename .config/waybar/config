{
"layer": "top",
"position": "top",
"height": 10,
"margin-bottom":0,
"margin-top":0,

"modules-left": ["sway/mode","cpu","memory","network","mpd"],
"modules-center": ["sway/workspaces","hyprland/workspaces"],
"modules-right":  ["tray","idle_inhibitor","pulseaudio","backlight","battery","clock"],

"battery": {
  "states": {
  "warning": 30,
  "critical": 15
  },
  "format": "{icon}&#8239;{capacity}%",
  "format-charging": "пГІ&#8239;{capacity}%",
  "format-plugged": "пГІ&#8239;{capacity}%",
  "format-alt": "{icon} {time}",
  "format-icons": ["пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пХЄ"]
},
"hyprland/workspaces": {
     "sort-by-name": true,
     "on-click": "activate"
},
"hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
},
"sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
},
"tray": {
    "icon-size": 16,
    "spacing": 6
},
"clock": {
    "locale": "C",
    "format": "пАЧвАГ{:%I:%M %p}",
    "format-alt": "пБ≥вАГ{:%a,%b %d}" // Icon: calendar-alt
},
"cpu": {
    "format": "пЛЫвАГ{usage}%",
    "tooltip": false,
    "on-click": "kitty -e 'htop'"
},
"memory": {
    "interval": 30,
    "format": "пГЙвАГ{used:0.2f}GB",
    "max-length": 10,
    "tooltip": false,
    "warning": 70,
    "critical": 90
},

"network": {
  "interval": 2,
  "format-wifi": "пЗЂвАГ{signalStrength}%",
  "format-ethernet": "пГБ",
  "format-linked": " {ipaddr}",
  "format-disconnected": "пБ±вАГDisconnected",
  "format-disabled": "",
  "tooltip": false,
  "max-length": 20,
  "min-length": 6,
  "format-alt": "{essid}",
},
"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "пБЃ",
        "deactivated": "пБ∞"
    }
},
"backlight": {
    // "device": "acpi_video1",
    "format": "{icon}&#8239;{percent}%",
    "format-icons": ["пГЂ", "пГЂ"],
    "on-scroll-down": "brightnessctl -c backlight set 1%-",
    "on-scroll-up": "brightnessctl -c backlight set +1%"
},
"pulseaudio": {
  // "scroll-step": 1, // %, can be a float
  "format": "{icon} {volume}%вАГ{format_source}",
  "format-bluetooth": "{icon}пКФвАГ{volume}% {format_source}",
  "format-bluetooth-muted": "пС¶вАГ{format_source}",
  "format-muted": "пС¶вАГ{format_source}",
  "format-source": "пД∞вАГ{volume}%",
  "format-source-muted": "пД±",
  "format-icons": {
    "headphone": "пА•",
    "hands-free": "пЦР",
    "headset": "рЯОІ",
    "phone": "пВХ",
    "portable": "пВХ",
    "car": "пЖє",
    "default": ["пА¶", "пАІ", "пА®"]
  },
  "on-click": "pavucontrol"
},
"mpd": {
  "format": "{stateIcon} {artist} - {title}",
  "format-disconnected": "рЯОґ",
  "format-stopped": "вЩ™",
  "interval": 10,
  "consume-icons": {
    "on": "пГД " // Icon shows only when "consume" is on
  },
  "random-icons": {
    "off": "<span color=\"#f53c3c\">пБі</span> ", // Icon grayed out when "random" is off
    "on": "пБі "
  },
  "repeat-icons": {
    "on": "пАЮ "
  },
  "single-icons": {
    "on": "пАЮ1 "
  },
  "state-icons": {
    "paused": "пБМ",
    "playing": "пБЛ"
  },
  "tooltip-format": "MPD (connected)",
  "tooltip-format-disconnected": "MPD (disconnected)",
  "max-length": 35
},
"custom/recorder": {
    "format": "пАљ Rec",
    "format-disabled": "пАљ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder",
},
"custom/audiorec": {
    "format": "вЩђ Rec",
    "format-disabled": "вЩђ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"audio recording\"}'",
    "exec-if": "pgrep ffmpeg",
},
}
