#!/usr/bin/env bash
set -euo pipefail

# Targets: macOS, Ubuntu, Arch
# Updates:
# - macOS: softwareupdate (prompted), Homebrew, mas (prompted)
# - Ubuntu: apt, snap, flatpak, fwupd (prompted)
# - Arch: pacman, AUR (yay/paru if present), flatpak, fwupd (prompted)

AUTO_YES=0
SKIP_MAS=0
SKIP_MACOS_UPDATES=0
SKIP_BREW=0
SKIP_SNAP=0
SKIP_FLATPAK=0
SKIP_AUR=0
SKIP_FWUPD=0

sudo_keepalive_pid=""

C_RESET='\033[0m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_RED='\033[31m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_BLUE='\033[34m'
C_CYAN='\033[36m'

msg_header() {
  printf "${C_BOLD}${C_CYAN}▶ %s${C_RESET}\n" "$*"
}

msg_section() {
  printf "\n${C_BOLD}${C_BLUE}━━━ %s ━━━${C_RESET}\n" "$*"
}

msg_task() {
  printf "${C_DIM}  → %s${C_RESET}\n" "$*"
}

msg_success() {
  printf "${C_GREEN}✓${C_RESET} %s\n" "$*"
}

msg_warn() {
  printf "${C_YELLOW}⚠${C_RESET} %s\n" "$*"
}

msg_error() {
  printf "${C_RED}✗${C_RESET} %s\n" "$*" >&2
}

msg_info() {
  printf "${C_CYAN}ℹ${C_RESET} %s\n" "$*"
}

usage() {
  cat <<'TEXT'
Usage:
  update-system.sh [options]

Options:
  -y, --yes            Non-interactive: assume "yes" for prompts
  --skip-macos         Skip macOS software updates (softwareupdate)
  --skip-mas           Skip Mac App Store updates (mas)
  --skip-brew          Skip Homebrew updates
  --skip-snap          Skip Snap refresh
  --skip-flatpak       Skip Flatpak updates
  --skip-aur           Skip AUR helper updates (yay/paru) on Arch
  --skip-fwupd         Skip firmware updates (fwupdmgr)
  -h, --help           Show help
TEXT
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -y|--yes)
        AUTO_YES=1
        shift
        ;;
      --skip-macos)
        SKIP_MACOS_UPDATES=1
        shift
        ;;
      --skip-mas)
        SKIP_MAS=1
        shift
        ;;
      --skip-brew)
        SKIP_BREW=1
        shift
        ;;
      --skip-snap)
        SKIP_SNAP=1
        shift
        ;;
      --skip-flatpak)
        SKIP_FLATPAK=1
        shift
        ;;
      --skip-aur)
        SKIP_AUR=1
        shift
        ;;
      --skip-fwupd)
        SKIP_FWUPD=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        msg_error "Unknown option: $1"
        echo
        usage
        exit 2
        ;;
    esac
  done
}

is_interactive() {
  [[ -t 0 && -t 1 ]]
}

confirm() {
  local prompt="$1"
  local reply=""

  if [[ "$AUTO_YES" -eq 1 ]]; then
    return 0
  fi

  if ! is_interactive; then
    return 1
  fi

  read -r -p "$(printf "${C_YELLOW}?${C_RESET} %s (y/N) " "$prompt")" -n 1 reply
  echo
  [[ "$reply" =~ ^[Yy]$ ]]
}

optional_run() {
  local label="$1"
  shift

  msg_task "$label"
  set +e
  "$@"
  local status=$?
  set -e

  if [[ $status -ne 0 ]]; then
    msg_warn "$label failed (exit $status). Continuing..."
  fi

  return 0
}

SUDO=()
init_sudo() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    SUDO=()
    return 0
  fi

  if command -v sudo >/dev/null 2>&1; then
    SUDO=(sudo)
    return 0
  fi

  SUDO=()
}

require_root_or_sudo() {
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    return 0
  fi

  if [[ ${#SUDO[@]} -eq 0 ]]; then
    msg_error "This operation requires root or sudo."
    exit 1
  fi
}

start_sudo_keepalive() {
  # No need to keep sudo alive if we're root
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    return 0
  fi

  # No sudo available
  if [[ ${#SUDO[@]} -eq 0 ]]; then
    return 0
  fi

  # If sudo does not require a password, skip keepalive entirely
  if "${SUDO[@]}" -n true 2>/dev/null; then
    return 0
  fi

  # Otherwise, validate once and keep alive
  "${SUDO[@]}" -v

  while sleep 60; do
    "${SUDO[@]}" -n true 2>/dev/null || true
  done &
  sudo_keepalive_pid=$!

  trap '[[ -n "${sudo_keepalive_pid:-}" ]] && kill "$sudo_keepalive_pid" 2>/dev/null || true' EXIT
}

detect_os() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo "macos"
    return 0
  fi

  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    source /etc/os-release
    echo "${ID:-unknown}"
    return 0
  fi

  echo "unknown"
}

update_fwupd() {
  if [[ "$SKIP_FWUPD" -eq 1 ]]; then
    return 0
  fi

  if ! command -v fwupdmgr >/dev/null 2>&1; then
    return 0
  fi

  require_root_or_sudo
  msg_section "Firmware Updates (fwupd)"

  "${SUDO[@]}" fwupdmgr refresh || true

  local updates_output updates_rc
  set +e
  updates_output=$("${SUDO[@]}" fwupdmgr get-updates 2>&1)
  updates_rc=$?
  set -e

  # Print raw output (don’t wrap in msg_info; it’s multiline)
  printf "%s\n" "$updates_output"

  # Treat “nothing to do” as success.
  # fwupdmgr commonly returns exit 2 in this case.
  if [[ $updates_rc -eq 2 ]]; then
    return 0
  fi

  # Also treat explicit “no updates” text as success, regardless of rc.
  if grep -qiE "no updates available|no updatable devices|nothing to do" \
    <<<"$updates_output"; then
    return 0
  fi

  # If we get here and it still failed, that’s a real-ish failure.
  if [[ $updates_rc -ne 0 ]]; then
    msg_warn "fwupdmgr get-updates failed (exit $updates_rc). Skipping."
    return 0
  fi

  # If it succeeded and doesn’t look like “no updates”, only then prompt/install.
  if confirm "Install firmware updates now?"; then
    "${SUDO[@]}" fwupdmgr update --assume-yes
  fi
}

update_flatpak() {
  if [[ "$SKIP_FLATPAK" -eq 1 ]]; then
    return 0
  fi

  if ! command -v flatpak >/dev/null 2>&1; then
    return 0
  fi

  msg_section "Flatpak Updates"
  optional_run "flatpak update" flatpak update -y
  optional_run "flatpak uninstall unused" flatpak uninstall --unused -y
}

update_snap() {
  if [[ "$SKIP_SNAP" -eq 1 ]]; then
    return 0
  fi

  if ! command -v snap >/dev/null 2>&1; then
    return 0
  fi

  msg_section "Snap Updates"
  require_root_or_sudo
  optional_run "snap refresh" "${SUDO[@]}" snap refresh
}

update_brew() {
  if [[ "$SKIP_BREW" -eq 1 ]]; then
    return 0
  fi

  if ! command -v brew >/dev/null 2>&1; then
    return 0
  fi

  msg_section "Homebrew Updates"
  optional_run "brew update" brew update
  optional_run "brew upgrade" brew upgrade
  optional_run "brew upgrade (casks)" brew upgrade --cask --greedy
  optional_run "brew cleanup" brew cleanup -s
  optional_run "brew autoremove" brew autoremove
}

update_mas() {
  if [[ "$SKIP_MAS" -eq 1 ]]; then
    return 0
  fi

  if ! command -v mas >/dev/null 2>&1; then
    return 0
  fi

  msg_section "Mac App Store Updates"
  optional_run "mas outdated" mas outdated

  if confirm "Upgrade Mac App Store apps via mas?"; then
    optional_run "mas upgrade" mas upgrade
  fi
}

update_macos_system() {
  if [[ "$SKIP_MACOS_UPDATES" -eq 1 ]]; then
    return 0
  fi

  if ! command -v softwareupdate >/dev/null 2>&1; then
    return 0
  fi

  msg_section "macOS System Updates"
  optional_run "softwareupdate --list" softwareupdate --list

  if confirm "Install macOS system updates now?"; then
    if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
      optional_run "softwareupdate --install --all" softwareupdate --install --all
    else
      if command -v sudo >/dev/null 2>&1; then
        optional_run "softwareupdate --install --all" sudo softwareupdate \
          --install --all
      else
        optional_run "softwareupdate --install --all" softwareupdate \
          --install --all
      fi
    fi
  fi
}

update_ubuntu() {
  require_root_or_sudo
  start_sudo_keepalive

  msg_section "Ubuntu: APT Updates"
  "${SUDO[@]}" apt update -q
  "${SUDO[@]}" apt full-upgrade -y
  "${SUDO[@]}" apt autoremove --purge -y
  "${SUDO[@]}" apt autoclean -y

  update_fwupd
  update_snap
  update_flatpak
}

update_arch_aur() {
  if [[ "$SKIP_AUR" -eq 1 ]]; then
    return 0
  fi

  # Never run AUR helpers with sudo/root.
  if command -v yay >/dev/null 2>&1; then
    msg_section "Arch: AUR Updates (yay)"
    optional_run "yay -Syu" yay -Syu --noconfirm
  elif command -v paru >/dev/null 2>&1; then
    msg_section "Arch: AUR Updates (paru)"
    optional_run "paru -Syu" paru -Syu --noconfirm
  fi
}

update_arch() {
  require_root_or_sudo
  start_sudo_keepalive

  msg_section "Arch: Pacman Updates"
  "${SUDO[@]}" pacman -Syu --noconfirm

  msg_task "Cleaning package cache..."
  if command -v paccache >/dev/null 2>&1; then
    "${SUDO[@]}" paccache -rk2
  else
    "${SUDO[@]}" pacman -Sc --noconfirm
  fi

  update_fwupd
  update_arch_aur
  update_flatpak
  update_snap
}

update_macos() {
  # brew/mas should be run as the user (not sudo)
  update_brew
  update_mas
  update_macos_system

  # Optional on macOS (rare, but harmless if installed)
  update_flatpak
}

main() {
  parse_args "$@"
  init_sudo

  local os
  os=$(detect_os)

  msg_info "Detected OS: $os"

  case "$os" in
    ubuntu)
      update_ubuntu
      ;;
    arch)
      update_arch
      ;;
    macos)
      update_macos
      ;;
    *)
      msg_error "This script is scoped to macOS, Ubuntu, and Arch. Detected: $os"
      exit 1
      ;;
  esac

  echo
  msg_success "All updates complete!"
}

main "$@"
